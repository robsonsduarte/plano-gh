{
  "language": "portuguese",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/post-edit-lint.sh $FILE_PATH"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/architecture-review.sh $FILE_PATH 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/security-gate.sh \"$INPUT\""
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/test-coverage-gate.sh \"$INPUT\" 2>/dev/null || true"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/dependency-audit.sh \"$INPUT\" 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/session-memory.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/scripts/redis-session-save.sh 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
